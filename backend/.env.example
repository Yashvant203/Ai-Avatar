# Copy to .env and fill in. Never commit the real .env.

# Environment: development | production
ENV=development

# SQLite database (relative paths resolve from the backend/ working dir)
DATABASE_URL=sqlite:///./ai_avatar.db

# Filesystem locations
STORAGE_DIR=../storage
ML_MODELS_DIR=../ml_models

# Auth — generate a strong secret, e.g.  python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
ACCESS_TTL=900            # access token lifetime, seconds (15 min)
REFRESH_TTL=1209600       # refresh token lifetime, seconds (14 days)

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000
